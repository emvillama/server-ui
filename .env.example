# Ollama has no auth by default, so no API key is needed here.

# Where Ollama is reachable from the backend.
# If backend and Ollama run on the same box: http://localhost:11434
# If backend runs elsewhere on the LAN: http://<server-ip>:11434
OLLAMA_HOST=http://localhost:11434

# Default model to use if a persona doesn't override it
DEFAULT_MODEL=llama3.1:8b

# Default embedding model to use
EMBEDDING_MODEL=nomic-embed-text

# SQLite file location (relative to project root)
DB_PATH=./data/persona_hub.db

# Request timeout (seconds) when calling Ollama
OLLAMA_TIMEOUT=120